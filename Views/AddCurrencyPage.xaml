<Page x:Class="CurrencyApp.Views.AddCurrencyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{StaticResource PageBgBrush}"
      Title="Add Currency">

  <!--
    ViewModel bindings expected (AddCurrencyViewModel):
      - string   CharCode            two-way
      - string   NumCode             two-way
      - string   Name                two-way
      - string   Id                  two-way  (CBR-style identifier, e.g. "R01235")
      - string   Nominal             two-way  (parsed to int in VM)
      - string   Value               two-way  (parsed to decimal in VM)
      - string   Previous            two-way  (parsed to decimal in VM)
      - string   ValidationMessage   one-way  (shown on error)
      - bool     CanAdd              one-way  (enables the Add button)
      - ICommand AddCurrencyCommand
      - ICommand ClearFormCommand
    -->

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- ===== Page Header ===== -->
      <Border Grid.Row="0"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderColorBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="28,18">
        <StackPanel>
          <TextBlock Text="Add Custom Currency"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
          <TextBlock Text="Create a currency entry with your own data"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,3,0,0"/>
        </StackPanel>
      </Border>

      <!-- ===== Form Card ===== -->
      <Border Grid.Row="1"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderColorBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="28,24,28,28"
                    Padding="32,28">

        <StackPanel MaxWidth="520" HorizontalAlignment="Left">

          <!-- Row 1: CharCode + NumCode -->
          <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CharCode -->
            <StackPanel Grid.Column="0">
              <TextBlock Text="Currency Code *"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,6"/>
              <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding CharCode, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="10"
                                     ToolTip="e.g. USD, EUR, GBP"/>
            </StackPanel>

            <!-- NumCode -->
            <StackPanel Grid.Column="2">
              <TextBlock Text="Numeric Code *"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,6"/>
              <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding NumCode, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="10"
                                     ToolTip="e.g. 840"/>
            </StackPanel>
          </Grid>

          <!-- Row 2: CBR ID -->
          <StackPanel Margin="0,0,0,18">
            <TextBlock Text="Identifier (CBR ID) *"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,6"/>
            <TextBox Style="{StaticResource FormTextBoxStyle}"
                                 Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="20"
                                 ToolTip="e.g. R01235 (optional for custom currencies)"/>
          </StackPanel>

          <!-- Row 4: Nominal -->
          <StackPanel Margin="0,0,0,18">
            <TextBlock Text="Nominal *"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,6"/>
            <TextBox Style="{StaticResource FormTextBoxStyle}"
                                 Text="{Binding Nominal, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="10"
                                 ToolTip="e.g. 1"/>
          </StackPanel>

          <!-- Row 5: Value + Previous -->
          <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Value -->
            <StackPanel Grid.Column="0">
              <TextBlock Text="Rate (RUB) *"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,6"/>
              <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="20"
                                     ToolTip="Current exchange rate in rubles"/>
            </StackPanel>

            <!-- Previous -->
            <StackPanel Grid.Column="2">
              <TextBlock Text="Previous Rate (RUB)"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,6"/>
              <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding Previous, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="20"
                                     ToolTip="Previous exchange rate in rubles (optional)"/>
            </StackPanel>
          </Grid>

          <!-- Validation Message -->
          <Border CornerRadius="4"
                            Background="#FDEDEC"
                            BorderBrush="{StaticResource DangerBrush}"
                            BorderThickness="1"
                            Padding="12,8"
                            Margin="0,0,0,16">
            <!-- Visible when HasValidationError = true (add to AddCurrencyViewModel) -->
            <Border.Visibility>
              <Binding Path="HasValidationError"
                                     Converter="{StaticResource BoolToVis}"
                                     FallbackValue="Collapsed"/>
            </Border.Visibility>
            <TextBlock Text="{Binding ValidationMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
          </Border>

          <!-- Action Buttons -->
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Style="{StaticResource SuccessButtonStyle}"
                                Content="Add Currency"
                                Command="{Binding AddCurrencyCommand}"
                                IsEnabled="true"
                                Margin="0,0,12,0"/>
            <Button Style="{StaticResource PrimaryButtonStyle}"
                                Content="Clear"
                                Command="{Binding ClearFormCommand}"
                                Background="{StaticResource TextSecondaryBrush}"/>
          </StackPanel>

        </StackPanel>
      </Border>

    </Grid>
  </ScrollViewer>
</Page>