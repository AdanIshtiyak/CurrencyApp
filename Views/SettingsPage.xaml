<Page x:Class="CurrencyApp.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{StaticResource PageBgBrush}"
      Title="Settings">

    <!--
    ViewModel bindings expected (SettingsViewModel):
      - string   LastSessionDateTime   one-way  (formatted date + time of previous launch)
      - bool     IsSqliteStorage       two-way  (RadioButton — SQLite selected)
      - bool     IsJsonStorage         two-way  (RadioButton — JSON selected)
      - ICommand ApplyStorageCommand            (saves storage preference)
    -->

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- ===== Page Header ===== -->
            <Border Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderColorBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="28,18">
                <StackPanel>
                    <TextBlock Text="Settings"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Application preferences and session information"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <!-- ===== Cards Container ===== -->
            <StackPanel Margin="28,24,28,28" MaxWidth="600" HorizontalAlignment="Left">

                <!-- ─────────────────────────────────── -->
                <!-- Card 1 · Last Session               -->
                <!-- ─────────────────────────────────── -->
                <Border Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="24,20"
                        Margin="0,0,0,20">
                    <StackPanel>

                        <TextBlock Text="SESSION INFO"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,14"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <Border Grid.Column="0"
                                    Width="40" Height="40"
                                    CornerRadius="20"
                                    Background="#EBF5FB"
                                    Margin="0,0,16,0">
                                <TextBlock Text="&#x23F0;"
                                           FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- Info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Last session started"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,4"/>
                                <!-- Binding: SettingsViewModel.LastSessionDateTime -->
                                <TextBlock Text="{Binding LastSessionDateTime, FallbackValue='No previous session recorded'}"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ─────────────────────────────────── -->
                <!-- Card 2 · Storage Type              -->
                <!-- ─────────────────────────────────── -->
                <Border Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderColorBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="24,20">
                    <StackPanel>

                        <TextBlock Text="DATA STORAGE"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,6"/>

                        <TextBlock Text="Choose where currency data is saved locally."
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,18"
                                   TextWrapping="Wrap"/>

                        <!-- SQLite Option -->
                        <Border CornerRadius="5"
                                BorderThickness="2"
                                Padding="16,14"
                                Margin="0,0,0,10"
                                Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush"
                                            Value="{StaticResource BorderColorBrush}"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSqliteStorage}" Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Background" Value="#EBF5FB"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0"
                                             IsChecked="{Binding IsSqliteStorage}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,14,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="SQLite Database"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,3"/>
                                    <TextBlock Text="Stores data in a local .db file. Fast and reliable."
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- JSON Option -->
                        <Border CornerRadius="5"
                                BorderThickness="2"
                                Padding="16,14"
                                Margin="0,0,0,20"
                                Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush"
                                            Value="{StaticResource BorderColorBrush}"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsJsonStorage}" Value="True">
                                            <Setter Property="BorderBrush"
                                                    Value="{StaticResource AccentBrush}"/>
                                            <Setter Property="Background" Value="#EBF5FB"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0"
                                             IsChecked="{Binding IsJsonStorage}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,14,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="JSON File"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,3"/>
                                    <TextBlock Text="Stores data as a human-readable currencies.json file."
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Apply Button -->
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Content="Apply Storage Setting"
                                Command="{Binding ApplyStorageCommand}"
                                HorizontalAlignment="Left"/>

                    </StackPanel>
                </Border>

            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>